{
  "name": "new-short-form-root",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:form": "npm run dev -w form",
    "dev:configurator": "npm run dev -w configurator",
    "dev": "concurrently \"npm run dev:form\" \"npm run dev:configurator\"",
    "build:form": "npm run build -w form",
    "build:configurator": "npm run build -w configurator",
    "webflow:share": "npm run webflow:share -w form"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
